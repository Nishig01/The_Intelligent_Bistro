{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "dev": "tsx backend/index.ts",
    "build": "node scripts/patch-import-meta.js && expo export --platform web && esbuild backend/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "postinstall": "node scripts/patch-import-meta.js",
    "start": "node dist/server.cjs",
    "expo:start": "expo start --web --port 8081",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.0",
    "@google/genai": "^1.29.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@shopify/flash-list": "^2.3.1",
    "babel-plugin-transform-define": "^2.1.4",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "^55.0.24",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "^55.0.14",
    "expo-crypto": "~55.0.15",
    "expo-haptics": "^55.0.14",
    "expo-image": "^55.0.10",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "^55.0.15",
    "expo-notifications": "^55.0.23",
    "expo-router": "^55.0.14",
    "expo-status-bar": "^2.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "lucide-react-native": "^1.16.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.0",
    "react-native-svg": "^15.15.5",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.19.13",
    "react-native-worklets": "^0.8.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
