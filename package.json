{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "dev": "tsx backend/index.ts",
    "build": "node scripts/patch-import-meta.js && expo export --platform web && esbuild backend/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "postinstall": "node scripts/patch-import-meta.js",
    "start": "node dist/server.cjs",
    "expo:start": "expo start --web --port 8081",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@google/genai": "^1.29.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@shopify/flash-list": "2.0.2",
    "babel-plugin-transform-define": "^2.1.4",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "54",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "lucide-react-native": "^1.16.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "~19.1.10",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
